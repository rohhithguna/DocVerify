# DocuVerify Environment Variables Configuration

# =============================================================================
# SECURITY: NEVER commit this file with real values to version control!
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (BUG #1 FIX - Required for Persistence)
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Without this, app uses in-memory storage (data lost on restart)
# 
# Local PostgreSQL:
DATABASE_URL=postgresql://postgres:password@localhost:5432/docuverify
#
# Neon (Serverless PostgreSQL - Recommended):
# Sign up at https://neon.tech (free tier available)
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/docuverify?sslmode=require
#
# Supabase:
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
#
# After setting DATABASE_URL:
#   1. Run migrations: npm run db:push
#   2. Start server: npm run dev
#   3. You should see: ✓ Database connection established

# -----------------------------------------------------------------------------
# CRYPTOGRAPHIC SIGNING KEYS (BUG #2 FIX)
# -----------------------------------------------------------------------------
# Generate RSA keypair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Then paste the ENTIRE content including BEGIN/END lines
SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END PRIVATE KEY-----"

SIGNING_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"

# -----------------------------------------------------------------------------
# BLOCKCHAIN CONFIGURATION (BUG #3 FIX)
# -----------------------------------------------------------------------------
# Ethereum Sepolia Testnet RPC URL
# Get free RPC endpoint from: https://infura.io or https://alchemy.com
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Wallet private key for signing blockchain transactions
# MUST be 64 hexadecimal characters with 0x prefix
# Get testnet ETH from: https://sepoliafaucet.com
BLOCKCHAIN_PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Blockchain network name (optional, defaults to 'sepolia')
BLOCKCHAIN_NETWORK=sepolia

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/docuverify

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# Server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=development

# Session secret for authentication (when implemented)
SESSION_SECRET=your-random-secret-key-change-this-in-production

# -----------------------------------------------------------------------------
# VERIFICATION INSTRUCTIONS
# -----------------------------------------------------------------------------
# After filling in values, verify configuration:
#   npm run dev
#
# You should see:
#   ✓ Cryptographic keys loaded from environment variables
#   ✓ Blockchain configuration validated for network: sepolia
#
# If you see errors, check:
#   1. Keys are in correct PEM format
#   2. Blockchain private key is exactly 66 characters (0x + 64 hex)
#   3. RPC URL starts with http:// or https://
